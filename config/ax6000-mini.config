#
# OpenWrt AX6000 Mini 精简配置 (适配官方源码)
# 适用机型: Redmi AX6000 (mediatek/filogic)
# 用途: 验证编译流程 / 排除插件冲突 / 快速测试
# 编译源: openwrt/openwrt (master)
#

CONFIG_MODULES=y
CONFIG_HAVE_DOT_CONFIG=y
CONFIG_HOST_OS_LINUX=y

# ============================================================================
# 🎯 目标平台与内核
# ============================================================================
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_xiaomi_redmi-router-ax6000=y
CONFIG_TARGET_BOARD="mediatek"
CONFIG_TARGET_SUBTARGET="filogic"
CONFIG_TARGET_PROFILE="DEVICE_xiaomi_redmi-router-ax6000"
CONFIG_TARGET_ARCH_PACKAGES="aarch64_cortex-a53"
CONFIG_DEFAULT_TARGET_OPTIMIZATION="-Os -pipe -mcpu=cortex-a53"
CONFIG_CPU_TYPE="cortex-a53"

# ✅ 修复: 使用官方稳定内核 6.6 (6.12 可能未完全适配)
CONFIG_LINUX_6_6=y
# CONFIG_LINUX_6_1=y
# CONFIG_LINUX_6_12=y

# ============================================================================
# 🧱 固件格式与根文件系统
# ============================================================================
CONFIG_TARGET_ROOTFS_INITRAMFS=y
CONFIG_TARGET_INITRAMFS_COMPRESSION_XZ=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256
CONFIG_TARGET_ROOTFS_PARTSIZE=448

# ============================================================================
# 📦 基础系统包 (最小化核心)
# ============================================================================
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y

# DNS/DHCP (使用完整版)
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq_full_dhcp=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_dnsmasq_full_dnssec=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_dnsmasq_full_tftp=y

# SSH/防火墙/网络工具
CONFIG_PACKAGE_dropbear=y
# ✅ 修复: filogic 平台使用 firewall4 (nftables)
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_fstools=y
CONFIG_PACKAGE_fwtool=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iptables=y
CONFIG_PACKAGE_iptables-mod-conntrack-extra=y
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_iwinfo=y

# 无线驱动 (AX6000 专属)
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_kmod-mt7915e=y
CONFIG_PACKAGE_kmod-mt7986-firmware=y
CONFIG_PACKAGE_kmod-nf-nathelper=y
CONFIG_PACKAGE_kmod-nf-nathelper-extra=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_mt7986-wo-firmware=y

# 系统核心库
CONFIG_PACKAGE_libc=y
CONFIG_PACKAGE_libgcc=y
CONFIG_PACKAGE_libiwinfo=y
CONFIG_PACKAGE_libubox=y
CONFIG_PACKAGE_libubus=y
CONFIG_PACKAGE_libuci=y
CONFIG_PACKAGE_logd=y
CONFIG_PACKAGE_mtd=y
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_procd-ujail=y
CONFIG_PACKAGE_uboot-envtools=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_uclient-fetch=y
CONFIG_PACKAGE_urandom-seed=y
CONFIG_PACKAGE_urngd=y

# WiFi 认证 (使用 openssl 版本)
CONFIG_PACKAGE_wpad-openssl=y
# CONFIG_PACKAGE_wpad-basic is not set

# ============================================================================
# 🎨 LuCI 基础界面 (最小化 + Argon 主题)
# ============================================================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lib-ip=y
CONFIG_PACKAGE_luci-lib-jsonc=y
CONFIG_PACKAGE_luci-lib-nixio=y

# ✅ 修复: 移除已废弃的 luci-mod-admin-full，使用标准模块
# CONFIG_PACKAGE_luci-mod-admin-full is not set
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-proto-ppp=y

# 主题: Bootstrap (官方) + Argon (第三方)
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# ============================================================================
# 🇨🇳 中文本地化 (仅基础)
# ============================================================================
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y

# ============================================================================
# 🛠️ 实用工具 (最小化)
# ============================================================================
CONFIG_PACKAGE_coremark=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_unzip=y

# ============================================================================
# ⚠️ 冲突包强制禁用区 (关键！)
# ============================================================================
# DNS: 禁用基础版，保留完整版
# CONFIG_PACKAGE_dnsmasq is not set

# 防火墙: 禁用旧版，保留 firewall4
# CONFIG_PACKAGE_firewall is not set
# CONFIG_PACKAGE_luci-app-firewall is not set

# FTP: 完全禁用
# CONFIG_PACKAGE_vsftpd is not set
# CONFIG_PACKAGE_vsftpd-alt is not set
# CONFIG_PACKAGE_luci-app-vsftpd is not set

# SSL 库: 统一使用 openssl
# CONFIG_PACKAGE_libustream-mbedtls is not set
# CONFIG_PACKAGE_libustream-wolfssl is not set

# 科学上网: 完全禁用 (mini 版不包含)
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_shadowsocks-libev is not set
# CONFIG_PACKAGE_xray-core is not set
# CONFIG_PACKAGE_sing-box is not set

# 其他大型插件: 禁用
# CONFIG_PACKAGE_luci-app-turboacc is not set
# CONFIG_PACKAGE_luci-app-adguardhome is not set
# CONFIG_PACKAGE_luci-app-openclash is not set
# CONFIG_PACKAGE_luci-app-ddns is not set

# ============================================================================
# 🔧 编译优化与全局设置 (官方兼容)
# ============================================================================
CONFIG_USE_MUSL=y
CONFIG_LIBC="musl"
CONFIG_TARGET_SUFFIX="musl"
CONFIG_SSP_SUPPORT=y
CONFIG_BINUTILS_VERSION_2_42=y
CONFIG_GCC_VERSION="13.3.0"

CONFIG_CCACHE=y
CONFIG_SSTRIP=y
CONFIG_SSTRIP_DISCARD_TRAILING_ZEROES=y

CONFIG_KERNEL_BUILD_USER="OpenWrt"
CONFIG_KERNEL_BUILD_DOMAIN="github-actions"

CONFIG_JSON_OVERVIEW_IMAGE_INFO=y
CONFIG_SIGNED_PACKAGES=y
CONFIG_SIGNATURE_CHECK=y
CONFIG_DOWNLOAD_CHECK_CERTIFICATE=y
CONFIG_SHADOW_PASSWORDS=y

CONFIG_PER_FEED_REPO=y
CONFIG_FEED_packages=y
CONFIG_FEED_luci=y
CONFIG_FEED_routing=y
CONFIG_FEED_telephony=y

CONFIG_KERNEL_CC_OPTIMIZE_FOR_PERFORMANCE=y
CONFIG_KERNEL_STACKPROTECTOR=y
CONFIG_PKG_RELRO_FULL=y
CONFIG_SECCOMP=y

# ============================================================================
# 📋 默认启用包 (最小化)
# ============================================================================
CONFIG_DEFAULT_base-files=y
CONFIG_DEFAULT_busybox=y
CONFIG_DEFAULT_dropbear=y
CONFIG_DEFAULT_firewall4=y
CONFIG_DEFAULT_luci=y
CONFIG_DEFAULT_luci-base=y
CONFIG_DEFAULT_luci-theme-argon=y
CONFIG_DEFAULT_mtd=y
CONFIG_DEFAULT_netifd=y
CONFIG_DEFAULT_odhcp6c=y
CONFIG_DEFAULT_odhcpd-ipv6only=y
CONFIG_DEFAULT_opkg=y
CONFIG_DEFAULT_ppp=y
CONFIG_DEFAULT_ppp-mod-pppoe=y
CONFIG_DEFAULT_procd=y
CONFIG_DEFAULT_procd-ujail=y
CONFIG_DEFAULT_uboot-envtools=y
CONFIG_DEFAULT_uci=y
CONFIG_DEFAULT_uclient-fetch=y
CONFIG_DEFAULT_urandom-seed=y
CONFIG_DEFAULT_urngd=y
CONFIG_DEFAULT_wpad-openssl=y
CONFIG_DEFAULT_kmod-mt7986-firmware=y
CONFIG_DEFAULT_mt7986-wo-firmware=y

# ============================================================================
# 🔒 开发选项 (保持关闭)
# ============================================================================
# CONFIG_DEVEL is not set
CONFIG_BINARY_FOLDER=""
CONFIG_DOWNLOAD_FOLDER=""
CONFIG_TARGET_ROOTFS_DIR=""
